{
  "layer": "top",
  "position": "top",
  
  "include": ["~/.config/waybar/modules/*.jsonc"],

  "modules-left": [
    "custom/applauncher", 
    "custom/phone",
    "custom/media"
  ],

  "modules-center": [
    "clock",
    "hyprland/workspaces"
  ],

  "modules-right": [
    "pulseaudio",
    "network",
    "custom/notification"
  ]
}